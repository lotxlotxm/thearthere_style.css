}
/* [3] 확장 구분선 (레드 콜아웃) - 갤러리 제외 버전 */
.notion-callout[class*="red"]:not(:has(.notion-collection-gallery)), 
div[style*="background-color: rgb(253, 235, 236)"]:not(:has(.notion-collection-gallery)) {
